// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "generate-test-images",
      "type": "shell",
      "command": "python3 test-data/generate_images.py",
      "presentation": {
        "reveal": "silent",
        "close": true
      },
      "group": "build"
    },
    {
      "label": "prepare-debug",
      "dependsOn": [
        "npm: watch",
        "generate-test-images"
      ],
      "group": "build"
    }
  ]
}
